<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- A minimal platform theme with no action bar. Compose supplies the real
         Material3 styling at runtime; this only needs to be a valid, action-bar-free
         window theme so we don't depend on the com.google.android.material library. -->
    <style name="Theme.CanRosettaCompanion" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:windowBackground">@android:color/white</item>
    </style>
</resources>
